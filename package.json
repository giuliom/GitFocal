{
  "name": "gitfocal",
  "displayName": "GitFocal",
  "description": "Lightweight Git branches & stashes views for VS Code with zero dependencies.",
  "version": "0.0.3",
  "publisher": "gitfocal",
  "repository": {
    "type": "git",
    "url": "https://github.com/giuliom/GitFocal"
  },
  "homepage": "https://github.com/giuliom/GitFocal",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "onView:gitfocal.branches",
    "onView:gitfocal.remotes",
    "onView:gitfocal.stashes",
    "onView:gitfocal.tags",
    "onStartupFinished"
  ],
  "main": "./src/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "colors": [
      {
        "id": "gitfocal.upstreamGoneForeground",
        "description": "Color for branches whose upstream has been deleted on the remote.",
        "defaults": {
          "dark": "#c97878",
          "light": "#a84040",
          "highContrast": "#ff8080",
          "highContrastLight": "#a84040"
        }
      }
    ],
    "viewsContainers": {},
    "views": {
      "scm": [
        { "id": "gitfocal.branches", "name": "Branches", "icon": "assets/icon.png" },
        { "id": "gitfocal.remotes", "name": "Remotes", "icon": "assets/icon.png" },
        { "id": "gitfocal.stashes", "name": "Stashes", "icon": "assets/icon.png" },
        { "id": "gitfocal.tags", "name": "Tags", "icon": "assets/icon.png" }
      ]
    },
    "commands": [
      { "command": "gitfocal.refresh", "title": "GitFocal: Refresh", "icon": "$(refresh)" },
      { "command": "gitfocal.createBranch", "title": "GitFocal: Create Branch", "icon": "$(add)" },
      { "command": "gitfocal.checkoutRemoteBranch", "title": "GitFocal: Checkout Remote Branch", "icon": "$(git-branch)" },
      { "command": "gitfocal.fetchAll", "title": "GitFocal: Fetch All", "icon": "$(cloud-download)" },
      { "command": "gitfocal.stashChanges", "title": "GitFocal: Stash Changes", "icon": "$(archive)" },
      { "command": "gitfocal.branches.filter", "title": "GitFocal: Filter Branches", "icon": "$(filter)" },
      { "command": "gitfocal.branches.clearFilter", "title": "GitFocal: Clear Branches Filter", "icon": "$(filter-filled)" },
      { "command": "gitfocal.branches.toggleHideSubmodules", "title": "GitFocal: Toggle Hide Submodules in Branches" },
      { "command": "gitfocal.branches.hideSubmodules", "title": "GitFocal: Hide Branch Submodules", "icon": "$(eye)" },
      { "command": "gitfocal.branches.showSubmodules", "title": "GitFocal: Show Branch Submodules", "icon": "$(eye-closed)" },
      { "command": "gitfocal.remotes.checkout", "title": "Checkout as Local Branch", "icon": "$(check)" },
      { "command": "gitfocal.remotes.createLocalFrom", "title": "Create Local Branch From...", "icon": "$(repo-create)" },
      { "command": "gitfocal.remotes.filter", "title": "GitFocal: Filter Remote Branches", "icon": "$(filter)" },
      { "command": "gitfocal.remotes.clearFilter", "title": "GitFocal: Clear Remote Branches Filter", "icon": "$(filter-filled)" },
      { "command": "gitfocal.remotes.toggleHideSubmodules", "title": "GitFocal: Toggle Hide Submodules in Remotes" },
      { "command": "gitfocal.remotes.hideSubmodules", "title": "GitFocal: Hide Remote Submodules", "icon": "$(eye)" },
      { "command": "gitfocal.remotes.showSubmodules", "title": "GitFocal: Show Remote Submodules", "icon": "$(eye-closed)" },
      { "command": "gitfocal.remotes.loadMoreCommits", "title": "Load More Commits" },
      { "command": "gitfocal.remotes.add", "title": "GitFocal: Add Remote", "icon": "$(add)" },
      { "command": "gitfocal.remotes.copyName", "title": "Copy Remote Name" },
      { "command": "gitfocal.remotes.copyUrl", "title": "Copy Remote URL" },
      { "command": "gitfocal.tags.filter", "title": "GitFocal: Filter Tags", "icon": "$(filter)" },
      { "command": "gitfocal.tags.clearFilter", "title": "GitFocal: Clear Tags Filter", "icon": "$(filter-filled)" },
      { "command": "gitfocal.stashes.toggleHideSubmodules", "title": "GitFocal: Toggle Hide Submodules in Stashes" },
      { "command": "gitfocal.stashes.hideSubmodules", "title": "GitFocal: Hide Stash Submodules", "icon": "$(eye)" },
      { "command": "gitfocal.stashes.showSubmodules", "title": "GitFocal: Show Stash Submodules", "icon": "$(eye-closed)" },

      { "command": "gitfocal.checkoutBranch", "title": "Checkout", "icon": "$(check)" },
      { "command": "gitfocal.createBranchFrom", "title": "Create Branch From..." },
      { "command": "gitfocal.renameBranch", "title": "Rename..." },
      { "command": "gitfocal.deleteBranch", "title": "Delete", "icon": "$(trash)" },
      { "command": "gitfocal.deleteBranchForce", "title": "Delete (force)" },
      { "command": "gitfocal.fetch", "title": "Fetch", "icon": "$(cloud-download)" },
      { "command": "gitfocal.pull", "title": "Pull", "icon": "$(repo-pull)" },
      { "command": "gitfocal.push", "title": "Push", "icon": "$(repo-push)" },
      { "command": "gitfocal.pushSetUpstream", "title": "Publish Branch", "icon": "$(cloud-upload)" },
      { "command": "gitfocal.merge", "title": "Merge into Current" },
      { "command": "gitfocal.rebase", "title": "Rebase Current onto..." },
      { "command": "gitfocal.squash", "title": "Squash Commits" },
      { "command": "gitfocal.reset", "title": "Reset Current to...", "icon": "$(discard)" },
      { "command": "gitfocal.changeUpstream", "title": "Change Upstream..." },
      { "command": "gitfocal.copyName", "title": "Copy Branch Name" },
      { "command": "gitfocal.copyUpstream", "title": "Copy Upstream Name" },
      { "command": "gitfocal.copyCommitHash", "title": "Copy Commit Hash" },
      { "command": "gitfocal.copyCommit", "title": "Copy Commit Hash", "icon": "$(copy)" },
      { "command": "gitfocal.cherryPickCommit", "title": "Cherry-pick Commit", "icon": "$(git-merge)" },
      { "command": "gitfocal.revertCommit", "title": "Revert Commit", "icon": "$(discard)" },
      { "command": "gitfocal.loadMoreCommits", "title": "Load More Commits" },

      { "command": "gitfocal.stashApply", "title": "Apply", "icon": "$(check)" },
      { "command": "gitfocal.stashPop", "title": "Pop", "icon": "$(arrow-up)" },
      { "command": "gitfocal.stashDelete", "title": "Delete", "icon": "$(trash)" },
      { "command": "gitfocal.stashRename", "title": "Rename...", "icon": "$(pencil)" },
      { "command": "gitfocal.stashDiff", "title": "Open Changes", "icon": "$(diff-multiple)" },
      { "command": "gitfocal.stashFileDiff", "title": "Open Changes", "icon": "$(diff-multiple)" },
      { "command": "gitfocal.stashApplyFile", "title": "Restore File from Stash", "icon": "$(check)" },

      { "command": "gitfocal.stashAllChanges", "title": "Stash All Changes", "icon": "$(archive)" },
      { "command": "gitfocal.stashStagedChanges", "title": "Stash Staged Changes", "icon": "$(archive)" },
      { "command": "gitfocal.stashUnstagedChanges", "title": "Stash Unstaged Changes", "icon": "$(archive)" },
      { "command": "gitfocal.stashSelectedChanges", "title": "Stash Selected Changes", "icon": "$(archive)" },

      { "command": "gitfocal.worktree.add", "title": "GitFocal: Add Worktree...", "icon": "$(add)" },
      { "command": "gitfocal.worktree.open", "title": "Open Worktree in New Window", "icon": "$(link-external)" },
      { "command": "gitfocal.worktree.addToWorkspace", "title": "Add Worktree to Workspace" },
      { "command": "gitfocal.worktree.remove", "title": "Remove Worktree", "icon": "$(trash)" },
      { "command": "gitfocal.worktree.lock", "title": "Lock Worktree..." },
      { "command": "gitfocal.worktree.unlock", "title": "Unlock Worktree" },
      { "command": "gitfocal.worktree.prune", "title": "GitFocal: Prune Worktrees" },
      { "command": "gitfocal.worktree.copyPath", "title": "Copy Worktree Path" },

      { "command": "gitfocal.createTag", "title": "GitFocal: Create Tag", "icon": "$(add)" },
      { "command": "gitfocal.deleteTag", "title": "Delete", "icon": "$(trash)" },
      { "command": "gitfocal.renameTag", "title": "Rename...", "icon": "$(pencil)" },
      { "command": "gitfocal.checkoutTag", "title": "Checkout Tag", "icon": "$(check)" },
      { "command": "gitfocal.pushTag", "title": "Push Tag", "icon": "$(cloud-upload)" },
      { "command": "gitfocal.deleteRemoteTag", "title": "Delete Remote Tag" },
      { "command": "gitfocal.copyTagName", "title": "Copy Tag Name" },
      { "command": "gitfocal.copyTagCommitHash", "title": "Copy Tag Commit Hash" },
      { "command": "gitfocal.tagCommit", "title": "Create Tag Here...", "icon": "$(tag)" },
      { "command": "gitfocal.pushAllTags", "title": "GitFocal: Push All Tags", "icon": "$(cloud-upload)" },
      { "command": "gitfocal.fetchTags", "title": "GitFocal: Fetch Tags", "icon": "$(cloud-download)" }
    ],
    "menus": {
      "view/title": [
        { "command": "gitfocal.createBranch", "when": "view == gitfocal.branches", "group": "navigation@1" },
        { "command": "gitfocal.fetchAll", "when": "view == gitfocal.branches", "group": "navigation@2" },
        { "command": "gitfocal.refresh", "when": "view == gitfocal.branches", "group": "navigation@3" },
        { "command": "gitfocal.branches.filter", "when": "view == gitfocal.branches && !gitfocal.branches.hasFilter", "group": "navigation@4" },
        { "command": "gitfocal.branches.clearFilter", "when": "view == gitfocal.branches && gitfocal.branches.hasFilter", "group": "navigation@4" },
        { "command": "gitfocal.branches.hideSubmodules", "when": "view == gitfocal.branches && !gitfocal.branches.hideSubmodules", "group": "2_visibility@1" },
        { "command": "gitfocal.branches.showSubmodules", "when": "view == gitfocal.branches && gitfocal.branches.hideSubmodules", "group": "2_visibility@1" },
        { "command": "gitfocal.worktree.add", "when": "view == gitfocal.branches", "group": "1_worktree@1" },
        { "command": "gitfocal.worktree.prune", "when": "view == gitfocal.branches", "group": "1_worktree@2" },
        { "command": "gitfocal.remotes.add", "when": "view == gitfocal.remotes", "group": "navigation@1" },
        { "command": "gitfocal.fetchAll", "when": "view == gitfocal.remotes", "group": "navigation@2" },
        { "command": "gitfocal.refresh", "when": "view == gitfocal.remotes", "group": "navigation@3" },
        { "command": "gitfocal.remotes.filter", "when": "view == gitfocal.remotes && !gitfocal.remotes.hasFilter", "group": "navigation@4" },
        { "command": "gitfocal.remotes.clearFilter", "when": "view == gitfocal.remotes && gitfocal.remotes.hasFilter", "group": "navigation@4" },
        { "command": "gitfocal.remotes.hideSubmodules", "when": "view == gitfocal.remotes && !gitfocal.remotes.hideSubmodules", "group": "navigation@5" },
        { "command": "gitfocal.remotes.showSubmodules", "when": "view == gitfocal.remotes && gitfocal.remotes.hideSubmodules", "group": "navigation@5" },
        { "command": "gitfocal.stashChanges", "when": "view == gitfocal.stashes", "group": "navigation@1" },
        { "command": "gitfocal.refresh", "when": "view == gitfocal.stashes", "group": "navigation@2" },
        { "command": "gitfocal.stashes.hideSubmodules", "when": "view == gitfocal.stashes && !gitfocal.stashes.hideSubmodules", "group": "navigation@3" },
        { "command": "gitfocal.stashes.showSubmodules", "when": "view == gitfocal.stashes && gitfocal.stashes.hideSubmodules", "group": "navigation@3" },
        { "command": "gitfocal.createTag", "when": "view == gitfocal.tags", "group": "navigation@1" },
        { "command": "gitfocal.refresh", "when": "view == gitfocal.tags", "group": "navigation@2" },
        { "command": "gitfocal.tags.filter", "when": "view == gitfocal.tags && !gitfocal.tags.hasFilter", "group": "navigation@3" },
        { "command": "gitfocal.tags.clearFilter", "when": "view == gitfocal.tags && gitfocal.tags.hasFilter", "group": "navigation@3" },
        { "command": "gitfocal.pushAllTags", "when": "view == gitfocal.tags", "group": "1_sync@1" },
        { "command": "gitfocal.fetchTags", "when": "view == gitfocal.tags", "group": "1_sync@2" }
      ],
      "view/item/context": [
        { "command": "gitfocal.checkoutBranch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "inline@1" },
        { "command": "gitfocal.worktree.open", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.local\\.worktree/", "group": "inline@1" },
        { "command": "gitfocal.pushSetUpstream", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\.(worktree\\.)?untracked$/", "group": "inline@2" },
        { "command": "gitfocal.fetch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "inline@3" },
        { "command": "gitfocal.pull", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "inline@4" },
        { "command": "gitfocal.push", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\./", "group": "inline@5" },
        { "command": "gitfocal.reset", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "inline@6" },

        { "command": "gitfocal.checkoutBranch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "1_checkout@1" },
        { "command": "gitfocal.worktree.open", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.local\\.worktree/", "group": "1_checkout@1" },
        { "command": "gitfocal.worktree.add", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.local\\.(tracking|untracked)$/", "group": "1_checkout@2" },
        { "command": "gitfocal.fetch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "2_remote@1" },
        { "command": "gitfocal.pull", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "2_remote@2" },
        { "command": "gitfocal.push", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\./", "group": "2_remote@3" },
        { "command": "gitfocal.pushSetUpstream", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\.(worktree\\.)?untracked$/", "group": "2_remote@3" },
        { "command": "gitfocal.reset", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "3_history@1" },
        { "command": "gitfocal.merge", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "3_history@2" },
        { "command": "gitfocal.rebase", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "3_history@3" },
        { "command": "gitfocal.squash", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "3_history@9" },
        { "command": "gitfocal.changeUpstream", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\./", "group": "4_upstream@1" },
        { "command": "gitfocal.renameBranch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(current|local)\\./", "group": "7_modify@1" },
        { "command": "gitfocal.deleteBranch", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "8_delete@1" },
        { "command": "gitfocal.deleteBranchForce", "when": "view == gitfocal.branches && viewItem =~ /^branch\\.(?!local\\.worktree)/", "group": "8_delete@2" },
        { "command": "gitfocal.copyName", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "9_copy@1" },
        { "command": "gitfocal.copyUpstream", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "9_copy@2" },
        { "command": "gitfocal.copyCommitHash", "when": "view == gitfocal.branches && viewItem =~ /^branch\\./", "group": "9_copy@3" },

        { "command": "gitfocal.worktree.add", "when": "view == gitfocal.branches && viewItem == group.worktrees", "group": "inline@1" },
        { "command": "gitfocal.worktree.add", "when": "view == gitfocal.branches && viewItem == group.worktrees", "group": "1_worktree@1" },
        { "command": "gitfocal.worktree.prune", "when": "view == gitfocal.branches && viewItem == group.worktrees", "group": "1_worktree@2" },

        { "command": "gitfocal.worktree.open", "when": "view == gitfocal.branches && viewItem =~ /^workTree/", "group": "inline@1" },
        { "command": "gitfocal.worktree.remove", "when": "view == gitfocal.branches && viewItem =~ /^workTree\\.linked/", "group": "inline@2" },
        { "command": "gitfocal.worktree.open", "when": "view == gitfocal.branches && viewItem =~ /^workTree/", "group": "1_open@1" },
        { "command": "gitfocal.worktree.addToWorkspace", "when": "view == gitfocal.branches && viewItem =~ /^workTree/", "group": "1_open@2" },
        { "command": "gitfocal.worktree.lock", "when": "view == gitfocal.branches && viewItem == workTree.linked", "group": "7_modify@1" },
        { "command": "gitfocal.worktree.unlock", "when": "view == gitfocal.branches && viewItem == workTree.linked.locked", "group": "7_modify@1" },
        { "command": "gitfocal.worktree.remove", "when": "view == gitfocal.branches && viewItem =~ /^workTree\\.linked/", "group": "8_delete@1" },
        { "command": "gitfocal.worktree.copyPath", "when": "view == gitfocal.branches && viewItem =~ /^workTree/", "group": "9_copy@1" },

        { "command": "gitfocal.cherryPickCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "inline@1" },
        { "command": "gitfocal.copyCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "inline@2" },
        { "command": "gitfocal.copyCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "9_copy@1" },
        { "command": "gitfocal.cherryPickCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "1_commit@1" },
        { "command": "gitfocal.revertCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "1_commit@3" },
        { "command": "gitfocal.reset", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "3_history@1" },

        { "command": "gitfocal.stashDiff", "when": "view == gitfocal.stashes && viewItem == stash", "group": "inline@0" },
        { "command": "gitfocal.stashApply", "when": "view == gitfocal.stashes && viewItem == stash", "group": "inline@1" },
        { "command": "gitfocal.stashPop", "when": "view == gitfocal.stashes && viewItem == stash", "group": "inline@2" },
        { "command": "gitfocal.stashDelete", "when": "view == gitfocal.stashes && viewItem == stash", "group": "inline@3" },

        { "command": "gitfocal.stashDiff", "when": "view == gitfocal.stashes && viewItem == stash", "group": "1_stash@0" },
        { "command": "gitfocal.stashApply", "when": "view == gitfocal.stashes && viewItem == stash", "group": "1_stash@1" },
        { "command": "gitfocal.stashPop", "when": "view == gitfocal.stashes && viewItem == stash", "group": "1_stash@2" },
        { "command": "gitfocal.stashRename", "when": "view == gitfocal.stashes && viewItem == stash", "group": "7_modify@1" },
        { "command": "gitfocal.stashDelete", "when": "view == gitfocal.stashes && viewItem == stash", "group": "8_delete@1" },

        { "command": "gitfocal.stashFileDiff", "when": "view == gitfocal.stashes && viewItem == stashFile", "group": "inline@0" },
        { "command": "gitfocal.stashApplyFile", "when": "view == gitfocal.stashes && viewItem == stashFile", "group": "inline@1" },
        { "command": "gitfocal.stashFileDiff", "when": "view == gitfocal.stashes && viewItem == stashFile", "group": "1_stash@0" },
        { "command": "gitfocal.stashApplyFile", "when": "view == gitfocal.stashes && viewItem == stashFile", "group": "1_stash@1" },

        { "command": "gitfocal.tagCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "inline@0" },
        { "command": "gitfocal.tagCommit", "when": "view == gitfocal.branches && viewItem =~ /^commit/", "group": "1_commit@2" },

        { "command": "gitfocal.remotes.checkout", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "inline@1" },
        { "command": "gitfocal.remotes.createLocalFrom", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "inline@2" },
        { "command": "gitfocal.fetch", "when": "view == gitfocal.remotes && viewItem == remote", "group": "inline@1" },
        { "command": "gitfocal.remotes.checkout", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "1_checkout@1" },
        { "command": "gitfocal.remotes.createLocalFrom", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "1_checkout@2" },
        { "command": "gitfocal.merge", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "2_history@1" },
        { "command": "gitfocal.rebase", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "2_history@2" },
        { "command": "gitfocal.copyName", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "9_copy@1" },
        { "command": "gitfocal.copyCommitHash", "when": "view == gitfocal.remotes && viewItem == remoteBranch", "group": "9_copy@2" },
        { "command": "gitfocal.fetch", "when": "view == gitfocal.remotes && viewItem == remote", "group": "1_remote@1" },
        { "command": "gitfocal.remotes.copyName", "when": "view == gitfocal.remotes && viewItem == remote", "group": "9_copy@1" },
        { "command": "gitfocal.remotes.copyUrl", "when": "view == gitfocal.remotes && viewItem == remote", "group": "9_copy@2" },

        { "command": "gitfocal.tagCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "inline@0" },
        { "command": "gitfocal.cherryPickCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "inline@1" },
        { "command": "gitfocal.copyCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "inline@2" },
        { "command": "gitfocal.tagCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "1_commit@2" },
        { "command": "gitfocal.cherryPickCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "1_commit@1" },
        { "command": "gitfocal.revertCommit", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "1_commit@3" },
        { "command": "gitfocal.reset", "when": "view == gitfocal.remotes && viewItem =~ /^commit/", "group": "3_history@1" },
